# Altitude backend environment configuration
# Copy to .env and fill in your values.

# SQLite database URL (Postgres-compatible; swap for Postgres in production)
DATABASE_URL=sqlite:///./altitude.db

# Allowed CORS origin for the frontend
FRONTEND_ORIGIN=http://localhost:3000

# Reported by GET /api/health
APP_VERSION=0.1.0

# Seeded broker account — created on first startup if no users exist.
# Set these to the primary broker's real details before first launch.
SEED_BROKER_NAME=Your Name
SEED_BROKER_EMAIL=you@example.com
SEED_BROKER_BROKERAGE=Your Brokerage
SEED_BROKER_LICENSE=
