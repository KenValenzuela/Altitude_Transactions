# --- Node / Next.js (frontend) ---
node_modules/
.next/
out/
*.tsbuildinfo
next-env.d.ts

# --- Python (backend) ---
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/

# --- Local data & uploads (never commit) ---
*.db
backend/uploads/*
!backend/uploads/.gitkeep

# --- Env files ---
.env
.env.local
.env.*.local

# --- misc ---
.DS_Store
*.pem

# --- IDE ---
.idea/

# --- AI assistant tooling (COBIT BAI10 / NIST CM-6) ---
# Developer tooling state is environment-level config, not application config.
# Committing it violates separation of concerns, pollutes audit history with
# tool churn, and introduces third-party scripts into the project supply chain
# (NIST SP 800-161 / SSDF PW.4). Skills reinstall automatically on first use.
#
# .claude/skills/  — Claude Code skill data and Python scripts (env-level tooling)
# .claude/settings.local.json — machine-specific overrides (never share)
# .agent/          — duplicate skill install created by the skill runner
# .github/prompts/ — skill prompt copies (.github/ kept for real CI workflows)
.claude/skills/
.claude/settings.local.json
.agent/
.github/prompts/
