# --- Node / Next.js (frontend) ---
node_modules/
.next/
out/
*.tsbuildinfo
next-env.d.ts

# --- Python (backend) ---
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/

# --- Local data & uploads (never commit) ---
*.db
backend/uploads/*
!backend/uploads/.gitkeep

# --- Env files ---
.env
.env.local
.env.*.local

# --- misc ---
.DS_Store
*.pem

# --- IDE ---
.idea/

# --- AI assistant tool artifacts (not needed in version control) ---
# .agent/ is a duplicate of .claude/skills/ installed by the skill runner
.agent/
# .github/prompts/ contains skill prompt copies; keep .github/ available for real CI workflows
.github/prompts/
# settings.local.json is machine-specific; .claude/skills/ is intentionally tracked
.claude/settings.local.json
